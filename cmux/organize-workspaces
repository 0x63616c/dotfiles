#!/usr/bin/env bash
# organize-workspaces — group cmux workspaces by their git repo.
#
# For every workspace in the current cmux window this script:
#   * resolves its working directory up to the enclosing git repo root
#     (a nested sub-folder of a repo counts as that repo)
#   * puts all workspaces that share a repo into one collapsible cmux
#     group named after the repo (lowercase basename)
#   * gives each repo group a stable, unique colour + SF Symbol icon
#   * sweeps every workspace that is NOT inside a git repo into a single
#     "other…" group pinned to the bottom of the sidebar
#
# Existing groups are reused (renamed / recoloured / re-iconed) rather than
# rebuilt, and membership is reconciled so re-running is idempotent.
#
# Usage:
#   organize-workspaces [--help|-h]        show this help (default with no args)
#   organize-workspaces install [--force]  symlink onto PATH + wire auto-run into ~/.zshrc
#     --force             relink even if the name on PATH points somewhere else
#   organize-workspaces run [options]      apply grouping now (logged)
#     -n, --dry-run       print the cmux commands, change nothing
#     --window <ref>      target a specific window
#   organize-workspaces logs [options]     view the run log
#     -f, --follow        stream new lines (tail -f)
#     -n, --lines <n>     show last n lines (default 200)
#   organize-workspaces test <name>        print the colour + icon chosen for <name>,
#                                          and whether each came from the palette
#                                          config or the name-hash fallback
#
# Colours + icons come from a palette config — one `<name> <#RRGGBB|-> [icon]`
# line per repo — at $XDG_CONFIG_HOME/organize-workspaces/palette.conf
# (override: ORGANIZE_PALETTE). `install` symlinks the copy shipped beside this
# script into place. Any repo not listed there gets a colour + icon hashed from
# its name: stable across runs, no config needed.
#
# Install target dir defaults to ~/.local/bin (override: ORGANIZE_BIN_DIR).
# Runs are logged to $XDG_STATE_HOME/organize-workspaces/run.log
# (override: ORGANIZE_LOG_FILE).
#
# Requires (for `run`/`install`): cmux (on PATH), jq, git.

set -euo pipefail

export CMUX_QUIET=1

ZSHRC="${ZDOTDIR:-$HOME}/.zshrc"
INSTALL_MARKER="# organize-workspaces: auto-run on shell start"
PATH_MARKER="# organize-workspaces: ensure install dir is on PATH"
BIN_DIR="${ORGANIZE_BIN_DIR:-$HOME/.local/bin}"

# Where every `run` (and the auto-run breadcrumb) is logged. Override with
# ORGANIZE_LOG_FILE. Kept in XDG state dir so it survives across shells.
LOG_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/organize-workspaces"
LOG_FILE="${ORGANIZE_LOG_FILE:-$LOG_DIR/run.log}"
LOG_MAX_LINES=2000   # trim the log to this many lines after each run

now() { date '+%Y-%m-%d %H:%M:%S'; }

# --- palette ------------------------------------------------------------
# Curated colour + icon per repo live in a config file, NOT in this script.
# Lookup order for any repo name:
#   1. the palette config (see PALETTE_FILE below)
#   2. a deterministic slot in the fallback arrays (stable for a given name)
#
# Config format — one repo per line, whitespace-separated:
#     <name>  <#RRGGBB|->  [sf-symbol-icon]
# `-` (or an omitted field) means "no override, fall back to the hash" for that
# column, so you can pin a colour without pinning an icon. A `#` at the start of
# a line, or after the three fields, starts a comment; blank lines are ignored.
# Names are matched lowercase (same as group names).
PALETTE_FILE="${ORGANIZE_PALETTE:-${XDG_CONFIG_HOME:-$HOME/.config}/organize-workspaces/palette.conf}"

declare -A PALETTE_COLOR=()
declare -A PALETTE_ICON=()
PALETTE_LOADED=0

# Parse PALETTE_FILE into PALETTE_COLOR / PALETTE_ICON. Missing file is not an
# error (the fallback hash covers everything). A malformed line warns with its
# line number and is skipped — one bad row must never take down a whole run.
load_palette() {
  [[ $PALETTE_LOADED -eq 1 ]] && return 0
  PALETTE_LOADED=1
  [[ -r "$PALETTE_FILE" ]] || return 0

  local lineno=0 line name color icon rest
  while IFS= read -r line || [[ -n "$line" ]]; do
    lineno=$((lineno + 1))
    # A `#` can't just be treated as "comment starts here" — #RRGGBB begins with
    # one. So: drop whole-line comments, then split into the three known fields
    # and let anything after them (a trailing comment) fall into `rest`.
    [[ "$line" =~ ^[[:space:]]*# ]] && continue
    read -r name color icon rest <<< "$line"   # collapses whitespace, trims
    [[ -z "$name" ]] && continue
    # `name #RRGGBB # note` would otherwise read "#" as the icon.
    [[ "$icon" == \#* ]] && icon=""

    name=$(printf '%s' "$name" | tr '[:upper:]' '[:lower:]')
    if [[ -n "$color" && "$color" != "-" ]]; then
      if [[ "$color" =~ ^#[0-9A-Fa-f]{6}$ ]]; then
        PALETTE_COLOR["$name"]="$color"
      else
        echo "organize-workspaces: $PALETTE_FILE:$lineno: bad colour '$color' (want #RRGGBB or -); ignoring" >&2
      fi
    fi
    [[ -n "$icon" && "$icon" != "-" ]] && PALETTE_ICON["$name"]="$icon"
  done < "$PALETTE_FILE"
  return 0   # the loop's final failed `read` must not trip `set -e`
}

FALLBACK_COLORS=(
  "#E74C3C" "#16A085" "#D35400" "#2980B9" "#C0392B" "#F39C12" "#9B59B6" "#1ABC9C"
  "#E67E22" "#34495E" "#3498DB" "#2ECC71" "#E84393" "#00CEC9" "#6C5CE7" "#FDCB6E"
  "#FD79A8" "#00B894" "#0984E3" "#D63031" "#A29BFE" "#55EFC4" "#FAB1A0" "#74B9FF"
  "#FF7675" "#81ECEC" "#B2BEC3" "#EE5A24" "#10AC84" "#5F27CD" "#FF9F43" "#01A3A4"
)
FALLBACK_ICONS=(
  folder cube.box hammer terminal chevron.left.forwardslash.chevron.right shippingbox book.closed leaf
  bolt.fill cpu flame puzzlepiece wrench.and.screwdriver network server.rack antenna.radiowaves.left.and.right
  lock.shield doc.text tray.full archivebox paperplane wand.and.stars gearshape.2 point.3.connected.trianglepath.dotted
  chart.bar waveform keyboard cursorarrow.rays globe.americas map flask atom
)

# Stable index from a name -> [0, n)
name_slot() {
  local name="$1" n="$2" sum
  sum=$(printf '%s' "$name" | cksum | cut -d' ' -f1)
  echo $(( sum % n ))
}

color_for() {
  local name="$1"
  load_palette
  if [[ -n "${PALETTE_COLOR[$name]:-}" ]]; then
    echo "${PALETTE_COLOR[$name]}"
    return 0
  fi
  local i; i=$(name_slot "$name" "${#FALLBACK_COLORS[@]}")
  echo "${FALLBACK_COLORS[$i]}"
}
icon_for() {
  local name="$1"
  load_palette
  if [[ -n "${PALETTE_ICON[$name]:-}" ]]; then
    echo "${PALETTE_ICON[$name]}"
    return 0
  fi
  local i; i=$(name_slot "$name" "${#FALLBACK_ICONS[@]}")
  echo "${FALLBACK_ICONS[$i]}"
}

OTHER_NAME="other…"
OTHER_COLOR="#566573"
OTHER_ICON="tray.full"

# swatch: #RRGGBB -> coloured ● (falls back to plain ● if not a hex)
swatch() {
  local hex="${1#\#}"
  [[ "$hex" =~ ^[0-9A-Fa-f]{6}$ ]] || { printf '●'; return; }
  printf '\033[38;2;%d;%d;%dm●\033[0m' "0x${hex:0:2}" "0x${hex:2:2}" "0x${hex:4:2}"
}

# --- help -----------------------------------------------------------------
print_help() {
  awk '
    NR==1 && /^#!/ { next }
    /^#/ { sub(/^# ?/, ""); print; next }
    { exit }
  ' "$0"
}

# --- test -------------------------------------------------------------------
cmd_test() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    echo "organize-workspaces test: missing <name>" >&2
    exit 2
  fi
  local lname; lname=$(printf '%s' "$name" | tr '[:upper:]' '[:lower:]')
  local color icon csrc isrc
  load_palette
  color=$(color_for "$lname")
  icon=$(icon_for "$lname")
  # Say where each value came from — otherwise a typo'd palette line looks
  # identical to a working one (both print *a* colour).
  csrc=$([[ -n "${PALETTE_COLOR[$lname]:-}" ]] && echo config || echo hash)
  isrc=$([[ -n "${PALETTE_ICON[$lname]:-}" ]] && echo config || echo hash)
  printf '%s  %-8s (%s)  %-45s (%s)  %s\n' \
    "$(swatch "$color")" "$color" "$csrc" "$icon" "$isrc" "$lname"
  [[ -r "$PALETTE_FILE" ]] || echo "  (no palette file at $PALETTE_FILE — everything hashes)" >&2
}

# --- install ------------------------------------------------------------
# Fully resolve a path (follow symlink chains, absolutise). Portable: macOS's
# BSD readlink has no -f, and realpath isn't guaranteed to be present.
resolve_path() {
  local p="$1" t
  while [[ -L "$p" ]]; do
    t=$(readlink "$p")
    [[ "$t" == /* ]] || t="$(dirname "$p")/$t"
    p="$t"
  done
  ( cd "$(dirname "$p")" 2>/dev/null && printf '%s/%s\n' "$(pwd -P)" "$(basename "$p")" )
}

# Remove the managed auto-run block (marker line through its closing col-0 `fi`)
# so install can rewrite an up-to-date version instead of leaving a stale one.
strip_autorun_block() {
  [[ -f "$ZSHRC" ]] || return 0
  awk -v m="$INSTALL_MARKER" '
    index($0, m)==1 { skip=1 }
    skip && $0=="fi" { skip=0; next }
    skip { next }
    { print }
  ' "$ZSHRC" > "$ZSHRC.tmp" && mv "$ZSHRC.tmp" "$ZSHRC"
}

cmd_install() {
  local force=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -f|--force) force=1; shift ;;
      -h|--help)  print_help; exit 0 ;;
      *) echo "organize-workspaces install: unknown arg: $1" >&2; exit 2 ;;
    esac
  done

  local self link
  self=$(resolve_path "${BASH_SOURCE[0]}")
  link="$BIN_DIR/organize-workspaces"

  # --- 1. symlink this script into BIN_DIR ---------------------------------
  mkdir -p "$BIN_DIR"
  if [[ -L "$link" ]]; then
    local cur; cur=$(resolve_path "$link")
    if [[ "$cur" == "$self" ]]; then
      echo "organize-workspaces: symlink already correct: $link -> $self"
    elif [[ $force -eq 1 ]]; then
      ln -sfn "$self" "$link"
      echo "organize-workspaces: relinked $link: $cur -> $self"
    else
      echo "organize-workspaces: $link already points elsewhere:" >&2
      echo "  current: $cur" >&2
      echo "  this:    $self" >&2
      echo "  re-run with --force to repoint it." >&2
      exit 1
    fi
  elif [[ -e "$link" ]]; then
    # a real file (not a symlink) is squatting the name — never clobber silently
    if [[ $force -eq 1 ]]; then
      ln -sfn "$self" "$link"
      echo "organize-workspaces: replaced regular file at $link with symlink -> $self"
    else
      echo "organize-workspaces: $link exists and is not a symlink; refusing to overwrite." >&2
      echo "  re-run with --force to replace it." >&2
      exit 1
    fi
  else
    ln -s "$self" "$link"
    echo "organize-workspaces: symlinked $link -> $self"
  fi

  # --- 2. symlink the shipped palette into place ---------------------------
  # Only if the repo ships one next to this script and nothing is there yet —
  # the config is yours to edit, so an existing file is never touched without
  # --force. No palette at all is fine: everything just hashes.
  local shipped="$(dirname "$self")/palette.conf"
  if [[ -f "$shipped" ]]; then
    mkdir -p "$(dirname "$PALETTE_FILE")"
    if [[ -L "$PALETTE_FILE" ]]; then
      local pcur; pcur=$(resolve_path "$PALETTE_FILE")
      if [[ "$pcur" == "$shipped" ]]; then
        echo "organize-workspaces: palette already linked: $PALETTE_FILE -> $shipped"
      elif [[ $force -eq 1 ]]; then
        ln -sfn "$shipped" "$PALETTE_FILE"
        echo "organize-workspaces: relinked palette: $pcur -> $shipped"
      else
        echo "organize-workspaces: $PALETTE_FILE points elsewhere ($pcur); leaving it (--force to repoint)" >&2
      fi
    elif [[ -e "$PALETTE_FILE" ]]; then
      echo "organize-workspaces: $PALETTE_FILE exists (not a symlink); leaving your copy alone"
    else
      ln -s "$shipped" "$PALETTE_FILE"
      echo "organize-workspaces: symlinked palette $PALETTE_FILE -> $shipped"
    fi
  fi

  # --- 3. make sure BIN_DIR is on PATH -------------------------------------
  if [[ ":$PATH:" == *":$BIN_DIR:"* ]]; then
    echo "organize-workspaces: $BIN_DIR already on PATH"
  elif [[ -f "$ZSHRC" ]] && grep -qF "$PATH_MARKER" "$ZSHRC"; then
    echo "organize-workspaces: PATH line already in $ZSHRC (open a new shell to pick it up)"
  else
    {
      echo ""
      echo "$PATH_MARKER"
      echo "export PATH=\"$BIN_DIR:\$PATH\""
    } >> "$ZSHRC"
    echo "organize-workspaces: added $BIN_DIR to PATH in $ZSHRC"
  fi

  # --- 4. warn if some OTHER organize-workspaces shadows us on PATH --------
  # BIN_DIR may sit late in PATH behind a stale copy or another clone — you'd
  # keep editing this file while a different one actually runs.
  local found
  found=$(command -v organize-workspaces 2>/dev/null || true)
  if [[ -n "$found" ]]; then
    local fres; fres=$(resolve_path "$found")
    if [[ "$fres" != "$self" ]]; then
      echo "organize-workspaces: WARNING — another organize-workspaces shadows this one on PATH:" >&2
      echo "  PATH resolves to: $found -> $fres" >&2
      echo "  this script is:   $self" >&2
      echo "  fix PATH order, or remove the other copy." >&2
    fi
  fi

  # --- 5. auto-run snippet --------------------------------------------------
  # Always (re)write the managed block so an older version gets refreshed in
  # place rather than left stale beside a duplicate.
  local had=0
  if [[ -f "$ZSHRC" ]] && grep -qF "$INSTALL_MARKER" "$ZSHRC"; then
    had=1
    strip_autorun_block
  fi
  # The snippet logs a breadcrumb every time it fires (so you can tell whether
  # ~/.zshrc actually ran it on shell start), then backgrounds the real run —
  # which self-logs its own output to the same file. If the command isn't on
  # PATH, that fact is logged too instead of vanishing silently.
  {
    echo ""
    echo "$INSTALL_MARKER — background, non-blocking, only inside a cmux workspace."
    echo 'if [[ -o interactive && -n $CMUX_WORKSPACE_ID ]]; then'
    echo '  _ow_log="${XDG_STATE_HOME:-$HOME/.local/state}/organize-workspaces/run.log"'
    echo '  mkdir -p "${_ow_log:h}" 2>/dev/null'
    echo '  if command -v organize-workspaces >/dev/null 2>&1; then'
    echo '    print -r -- "[$(date "+%Y-%m-%d %H:%M:%S")] autorun: shell start in $CMUX_WORKSPACE_ID -> launching run" >>"$_ow_log"'
    echo '    (organize-workspaces run >/dev/null 2>&1 &) 2>/dev/null'
    echo '  else'
    echo '    print -r -- "[$(date "+%Y-%m-%d %H:%M:%S")] autorun: organize-workspaces NOT on PATH; skipped" >>"$_ow_log"'
    echo '  fi'
    echo '  unset _ow_log'
    echo 'fi'
  } >> "$ZSHRC"
  if [[ $had -eq 1 ]]; then
    echo "organize-workspaces: refreshed auto-run block in $ZSHRC"
  else
    echo "organize-workspaces: installed auto-run into $ZSHRC"
  fi
}

# --- run ----------------------------------------------------------------
cmd_run() {
DRY_RUN=0
WINDOW_ARGS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    -n|--dry-run) DRY_RUN=1; shift ;;
    --window)     WINDOW_ARGS=(--window "$2"); shift 2 ;;
    -h|--help)    print_help; exit 0 ;;
    *) echo "organize-workspaces run: unknown arg: $1" >&2; exit 2 ;;
  esac
done

# Self-log every real run: tee all stdout+stderr to LOG_FILE so a backgrounded
# auto-run (whose output the ~/.zshrc snippet throws at /dev/null) is still
# captured for later inspection via `organize-workspaces logs`. Dry-runs are
# left alone — they change nothing and are meant for the terminal.
if [[ $DRY_RUN -eq 0 ]]; then
  mkdir -p "$LOG_DIR" 2>/dev/null || true
  exec > >(tee -a "$LOG_FILE") 2>&1
  echo "=== $(now) run (pid $$, cwd $PWD${WINDOW_ARGS[*]:+, window ${WINDOW_ARGS[*]}}) ==="
fi

for bin in cmux jq git; do
  command -v "$bin" >/dev/null 2>&1 || { echo "organize-workspaces: missing dependency: $bin" >&2; exit 1; }
done

# Preflight: wait for cmux to answer RPC before touching anything. On shell
# start (the auto-run path) the daemon socket isn't accepting yet, so the first
# call dies with "Failed to write to socket (Broken pipe)". Probe until it
# responds — up to ~15s — instead of aborting the whole run on that race.
tries=0
until cmux workspace list --json "${WINDOW_ARGS[@]}" >/dev/null 2>&1; do
  tries=$((tries+1))
  if [[ $tries -ge 30 ]]; then
    echo "organize-workspaces: cmux not responding after ${tries} probes; aborting" >&2
    exit 1
  fi
  [[ $tries -eq 1 ]] && echo "organize-workspaces: waiting for cmux to become ready…"
  sleep 0.5
done
[[ $tries -gt 0 ]] && echo "organize-workspaces: cmux ready after ${tries} probe(s)"

run() {
  if [[ $DRY_RUN -eq 1 ]]; then
    printf 'DRY  cmux'; printf ' %q' "$@"; printf '\n'
  else
    printf 'RUN  cmux'; printf ' %q' "$@"; printf '\n'
    cmux "$@"
  fi
}

# --- gather workspaces -------------------------------------------------------
GROUPS_JSON=$(cmux workspace-group list --json "${WINDOW_ARGS[@]}")

# Remove empty groups: a group whose only member is its (throwaway) anchor has
# no real workspaces under it. `delete` closes that bare anchor and drops the
# group. Healthy groups always have the anchor + ≥1 real member (count ≥ 2).
mapfile -t EMPTY_GROUPS < <(printf '%s' "$GROUPS_JSON" | jq -r '.groups[]|select(.member_count<=1)|.ref')
for g in "${EMPTY_GROUPS[@]:-}"; do [[ -n "$g" ]] && run workspace-group delete "$g"; done
if [[ ${#EMPTY_GROUPS[@]} -gt 0 && $DRY_RUN -eq 0 ]]; then
  GROUPS_JSON=$(cmux workspace-group list --json "${WINDOW_ARGS[@]}")
fi

WS_JSON=$(cmux workspace list --json "${WINDOW_ARGS[@]}")

# other…'s anchor is itself non-git; don't let it count as a "real" ungrouped
# workspace, else the group would keep re-creating itself for its own anchor.
OTHER_ANCHOR=$(printf '%s' "$GROUPS_JSON" | jq -r --arg n "$OTHER_NAME" '.groups[]|select(.name==$n)|.anchor_workspace_ref' | head -1)

# repo_of <dir> -> prints repo root, or empty if not in a git repo
repo_of() {
  local dir="$1"
  [[ -n "$dir" && -d "$dir" ]] || { echo ""; return; }
  git -C "$dir" rev-parse --show-toplevel 2>/dev/null || echo ""
}

# Build parallel arrays: ws ref, repo root ("" == other), lowercased repo name.
declare -a WS_REFS WS_KEYS WS_NAMES
while IFS=$'\t' read -r ref dir; do
  [[ -n "$ref" ]] || continue
  root=$(repo_of "$dir")
  if [[ -n "$root" ]]; then
    name=$(basename "$root" | tr '[:upper:]' '[:lower:]')
    WS_KEYS+=("$root")
  else
    name="$OTHER_NAME"
    WS_KEYS+=("__other__")
  fi
  WS_REFS+=("$ref")
  WS_NAMES+=("$name")
done < <(printf '%s' "$WS_JSON" | jq -r '.workspaces[] | [.ref, (.current_directory // "")] | @tsv')

# Unique repo keys, sorted alphabetically by display name; __other__ forced last.
declare -a KEYS
# collect "name<TAB>key" for unique repo keys (skip __other__)
declare -a PAIRS
for i in "${!WS_KEYS[@]}"; do
  k="${WS_KEYS[$i]}"
  [[ "$k" == "__other__" ]] && continue
  seen=0; for e in "${KEYS[@]:-}"; do [[ "$e" == "$k" ]] && seen=1 && break; done
  [[ $seen -eq 1 ]] && continue
  KEYS+=("$k")
  PAIRS+=("${WS_NAMES[$i]}"$'\t'"$k")
done
# re-derive KEYS in name order
KEYS=()
while IFS=$'\t' read -r _ k; do [[ -n "$k" ]] && KEYS+=("$k"); done \
  < <(printf '%s\n' "${PAIRS[@]:-}" | LC_ALL=C sort -f)
# Count REAL ungrouped workspaces — non-git, excluding other…'s own anchor.
real_strays=0
for i in "${!WS_KEYS[@]}"; do
  [[ "${WS_KEYS[$i]}" == "__other__" ]] || continue
  [[ "${WS_REFS[$i]}" == "$OTHER_ANCHOR" ]] && continue
  real_strays=$((real_strays+1))
done
# Genuine strays -> keep/create the other… group. (An other… group left with
# only its own anchor is already gone via the empty-group sweep above.)
[[ $real_strays -gt 0 ]] && KEYS+=("__other__")

# --- existing groups: map anchor's repo root -> group ref --------------------

# name -> current_directory for anchor lookup
anchor_dir() {
  printf '%s' "$WS_JSON" | jq -r --arg r "$1" '.workspaces[] | select(.ref==$r) | .current_directory // ""'
}

# find existing group ref whose anchor lives in repo root $1 (or __other__ by name)
group_for_key() {
  local key="$1"
  local n=$(printf '%s' "$GROUPS_JSON" | jq '.groups | length')
  for ((g=0; g<n; g++)); do
    local gref aref name
    gref=$(printf '%s' "$GROUPS_JSON" | jq -r ".groups[$g].ref")
    aref=$(printf '%s' "$GROUPS_JSON" | jq -r ".groups[$g].anchor_workspace_ref")
    name=$(printf '%s' "$GROUPS_JSON" | jq -r ".groups[$g].name")
    if [[ "$key" == "__other__" ]]; then
      [[ "$name" == "$OTHER_NAME" ]] && { echo "$gref"; return 0; }
    else
      local adir aroot
      adir=$(anchor_dir "$aref")
      aroot=$(repo_of "$adir")
      [[ "$aroot" == "$key" ]] && { echo "$gref"; return 0; }
    fi
  done
  return 1
}

group_members() {  # group ref -> member ws refs, one per line
  printf '%s' "$GROUPS_JSON" | jq -r --arg g "$1" '.groups[] | select(.ref==$g) | .member_workspace_refs[]'
}

# group ref that ws $1 anchors, or "" if it isn't an anchor
group_anchored_by() {
  printf '%s' "$GROUPS_JSON" | jq -r --arg m "$1" '.groups[] | select(.anchor_workspace_ref==$m) | .ref' | head -1
}

# workspace refs belonging to key, space-joined
ws_for_key() {
  local key="$1" i out=""
  for i in "${!WS_KEYS[@]}"; do
    [[ "${WS_KEYS[$i]}" == "$key" ]] && out+="${WS_REFS[$i]} "
  done
  echo "$out"
}

# display name for key
name_for_key() {
  local key="$1" i
  [[ "$key" == "__other__" ]] && { echo "$OTHER_NAME"; return; }
  for i in "${!WS_KEYS[@]}"; do
    [[ "${WS_KEYS[$i]}" == "$key" ]] && { echo "${WS_NAMES[$i]}"; return; }
  done
}

# Read one field of a group out of GROUPS_JSON (kept fresh as we mutate).
gget() { printf '%s' "$GROUPS_JSON" | jq -r --arg g "$1" --arg f "$2" '.groups[]|select(.ref==$g)|.[$f] // ""'; }

# --- reconcile each group: create/add members, then rename/colour/icon, only
# --- issuing a cmux call when the current value actually differs (no churn on
# --- re-runs). Colours/order are applied in one atomic pass afterwards.
declare -a ORDERED_GROUP_REFS
declare -A GREF_COLOR
for key in "${KEYS[@]}"; do
  gname=$(name_for_key "$key")
  members=$(ws_for_key "$key"); members=${members% }
  IFS=' ' read -r -a mrefs <<< "$members"

  if [[ "$key" == "__other__" ]]; then
    gcolor="$OTHER_COLOR"; gicon="$OTHER_ICON"
  else
    gcolor=$(color_for "$gname"); gicon=$(icon_for "$gname")
  fi

  gref=$(group_for_key "$key" || true)

  if [[ -z "$gref" ]]; then
    from=$(IFS=,; echo "${mrefs[*]}")
    if [[ $DRY_RUN -eq 1 ]]; then
      run workspace-group create --name "$gname" --from "$from" "${WINDOW_ARGS[@]}"
      gref="workspace_group:NEW($gname)"
    else
      # `create` mints a dedicated anchor workspace and prints "OK <group ref>";
      # capture that ref directly (re-listing can't match it — the new anchor's
      # cwd is not the repo).
      printf 'RUN  cmux workspace-group create --name %q --from %q\n' "$gname" "$from"
      created=$(cmux workspace-group create --name "$gname" --from "$from" "${WINDOW_ARGS[@]}")
      echo "$created"
      gref=$(printf '%s' "$created" | grep -oE 'workspace_group:[0-9]+' | head -1)
      GROUPS_JSON=$(cmux workspace-group list --json "${WINDOW_ARGS[@]}")
    fi
  else
    [[ "$(gget "$gref" name)" == "$gname" ]] || run workspace-group rename "$gref" --name "$gname"
    existing=$(group_members "$gref" 2>/dev/null || true)
    for m in "${mrefs[@]}"; do
      grep -qx "$m" <<< "$existing" && continue
      # a workspace that anchors its own group can't be added to another
      # group directly; ungroup its old group first (its other members fall
      # back into the pool and get reconciled into their own repo groups).
      ag=$(group_anchored_by "$m")
      if [[ -n "$ag" && "$ag" != "$gref" ]]; then
        run workspace-group ungroup "$ag"
        GROUPS_JSON=$(cmux workspace-group list --json "${WINDOW_ARGS[@]}")
      fi
      run workspace-group add --group "$gref" --workspace "$m"
    done
  fi

  [[ -n "$gref" ]] || { echo "organize-workspaces: could not resolve group for '$gname'" >&2; continue; }
  [[ "$(gget "$gref" custom_color)" == "$gcolor" ]] || run workspace-group set-color "$gref" --hex "$gcolor"
  [[ "$(gget "$gref" icon_symbol)"  == "$gicon"  ]] || run workspace-group set-icon  "$gref" --symbol "$gicon"

  GREF_COLOR["$gref"]="$gcolor"
  ORDERED_GROUP_REFS+=("$gref")
done

# --- apply colours + order in one atomic pass -------------------------------
# Re-read live state once, then: tint each member workspace to its group colour
# (skipping any already-correct), and compute the full desired workspace order
# so a single `reorder-workspaces` places everything at once (no per-group
# shuffle). Pinned groups float to the top — cmux owns that — so they are left
# out of the order list but their members are still tinted.
GROUPS_JSON=$(cmux workspace-group list --json "${WINDOW_ARGS[@]}")
WS_META=$(cmux workspace list --json "${WINDOW_ARGS[@]}" | jq -r '.workspaces[] | [.ref, (.custom_color//""), (.description//""), (.current_directory//"")] | @tsv')
ws_field() { awk -F'\t' -v r="$1" -v c="$2" '$1==r{print $c}' <<< "$WS_META"; }

# git branch of a workspace's dir (empty if not a git repo)
branch_of() { git -C "$1" branch --show-current 2>/dev/null || true; }

declare -a ORDER
for gref in "${ORDERED_GROUP_REFS[@]}"; do
  gcolor="${GREF_COLOR[$gref]}"
  if [[ "$gref" == workspace_group:NEW* ]]; then
    members=("${mrefs[@]}"); is_pinned="false"      # dry-run best-effort
  else
    mapfile -t members < <(printf '%s' "$GROUPS_JSON" | jq -r --arg g "$gref" '.groups[]|select(.ref==$g)|.member_workspace_refs[]')
    is_pinned=$(gget "$gref" is_pinned)
  fi
  for m in "${members[@]}"; do
    [[ -n "$m" ]] || continue
    # colour: tint member to its group colour
    [[ "$(ws_field "$m" 2)" == "$gcolor" ]] || run workspace-action set-color --workspace "$m" --color "$gcolor" "${WINDOW_ARGS[@]}"
    # description: show the git branch (extra info in the sidebar)
    br=$(branch_of "$(ws_field "$m" 4)")
    if [[ -n "$br" && "$(ws_field "$m" 3)" != "$br" ]]; then
      run workspace-action set-description --workspace "$m" --description "$br" "${WINDOW_ARGS[@]}"
    fi
    [[ "$is_pinned" == "true" ]] || ORDER+=("$m")   # pinned members keep their top slot
  done
done

if [[ ${#ORDER[@]} -gt 0 ]]; then
  order_csv=$(IFS=,; echo "${ORDER[*]}")
  run reorder-workspaces --order "$order_csv" "${WINDOW_ARGS[@]}"
fi

# --- print the resulting sidebar tree ---------------------------------------
# A colour swatch (truecolor if the terminal supports it) + icon per group,
# with member workspace titles indented beneath. Skipped in --dry-run.
print_tree() {
  local gjson wjson
  gjson=$(cmux workspace-group list --json "${WINDOW_ARGS[@]}")
  wjson=$(cmux workspace list --json "${WINDOW_ARGS[@]}")
  local anchors
  anchors=$(printf '%s' "$gjson" | jq -r '.groups[] | [.anchor_workspace_ref, .ref, .name, (.custom_color//""), (.icon_symbol//""), (.is_pinned|tostring)] | @tsv')
  echo
  # walk workspaces in sidebar order; emit a header when a row is a group anchor
  printf '%s' "$wjson" | jq -r '.workspaces[] | [.ref, .title, (.description//"")] | @tsv' | \
  while IFS=$'\t' read -r ref title desc; do
    local meta; meta=$(awk -F'\t' -v r="$ref" '$1==r{print; exit}' <<< "$anchors")
    if [[ -n "$meta" ]]; then
      IFS=$'\t' read -r _ _ gname gcolor gicon gpin <<< "$meta"
      local pin=""; [[ "$gpin" == "true" ]] && pin="  \033[2m(pinned)\033[0m"
      printf '%b %s  \033[2m%s\033[0m%b\n' "$(swatch "$gcolor")" "$gname" "${gicon:-—}" "$pin"
    else
      local br=""; [[ -n "$desc" ]] && br="  \033[2m[$desc]\033[0m"
      printf '   \033[2m•\033[0m %s%b\n' "$title" "$br"
    fi
  done
}
[[ $DRY_RUN -eq 0 ]] && print_tree

echo "organize-workspaces: done."

# Keep the log bounded — trim to the last LOG_MAX_LINES lines. tee has already
# flushed this run's output by the time the script exits; trimming here (before
# exit) is a best-effort cap, so failure is non-fatal.
if [[ $DRY_RUN -eq 0 && -f "$LOG_FILE" ]]; then
  if [[ $(wc -l < "$LOG_FILE") -gt $LOG_MAX_LINES ]]; then
    tail -n "$LOG_MAX_LINES" "$LOG_FILE" > "$LOG_FILE.tmp" 2>/dev/null && mv "$LOG_FILE.tmp" "$LOG_FILE" || rm -f "$LOG_FILE.tmp"
  fi
fi
}

# --- logs -------------------------------------------------------------------
cmd_logs() {
  local follow=0 lines=200
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -f|--follow) follow=1; shift ;;
      -n|--lines)  lines="$2"; shift 2 ;;
      -h|--help)   print_help; exit 0 ;;
      *) echo "organize-workspaces logs: unknown arg: $1" >&2; exit 2 ;;
    esac
  done
  if [[ ! -f "$LOG_FILE" ]]; then
    echo "organize-workspaces: no log yet at $LOG_FILE" >&2
    echo "  (it's written on the first \`run\`; auto-run logs a breadcrumb on shell start)" >&2
    exit 1
  fi
  echo "# $LOG_FILE" >&2
  if [[ $follow -eq 1 ]]; then
    tail -n "$lines" -f "$LOG_FILE"
  else
    tail -n "$lines" "$LOG_FILE"
  fi
}

# --- dispatch ----------------------------------------------------------------
cmd="${1:-}"
case "$cmd" in
  ""|--help|-h|help)
    print_help
    ;;
  install)
    shift
    cmd_install "$@"
    ;;
  run)
    shift
    cmd_run "$@"
    ;;
  logs)
    shift
    cmd_logs "$@"
    ;;
  test)
    shift
    cmd_test "$@"
    ;;
  *)
    echo "organize-workspaces: unknown command: $cmd" >&2
    echo >&2
    print_help >&2
    exit 2
    ;;
esac
