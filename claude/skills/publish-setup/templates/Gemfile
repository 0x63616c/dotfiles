source "https://rubygems.org"

# Pinned, and the repo MUST commit its Gemfile.lock (skill step 6): an unpinned
# fastlane let CI float onto 2.236.0, whose altool upload path rejects IPAs with
# "file isn't in the correct format (259)" and killed every TestFlight upload
# (control-center CC-84ti, 2026-06-09). Bump deliberately, then verify a real
# upload_to_testflight run before widening the bound.
gem "fastlane", "~> 2.235", "< 2.236"
# fastlane 2.235+ loads its Google Play actions at startup, which `require "multi_json"`,
# but it's no longer pulled into the bundle transitively — without this the release
# lane dies with "multi_json is not part of the bundle" before any lane runs.
gem "multi_json"
